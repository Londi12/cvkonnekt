|'deleted'|'moved'|'root-changed'|'unknown'} FsEventsEvent\n * @typedef {'file'|'directory'|'symlink'} FsEventsType\n */\n{\n  \"event\": \"created\",\n  \"path\": \"file.txt\", // {FsEventsEvent}\n  \"type\": \"file\",    // {FsEventsType}\n  \"changes\": {\n    \"inode\": true,   // Had iNode Meta-Information changed\n    \"finder\": false, // Had Finder Meta-Data changed\n    \"access\": false, // Had access permissions changed\n    \"xattrs\": false  // Had xAttributes changed\n  },\n  \"flags\": 0x100000000\n}\n```\n\n## License\n\nThe MIT License Copyright (C) 2010-2018 by Philipp Dunkel, Ben Noordhuis, Elan Shankar — see LICENSE file.\n\nVisit our [GitHub page](https://github.com/fsevents/fsevents) and [NPM Page](https://npmjs.org/package/fsevents)\n","engines":{"node":"^8.16.0 || ^10.6.0 || >=11.0.0"},"gitHead":"6e16b1a4589c422d98aa084fb450196cfefc2ed5","scripts":{"test":"/bin/bash ./test.sh 2>/dev/null","clean":"node-gyp clean && rm -f fsevents.node","install":"[ -f fsevents.node ] || npm run prepublishOnly","prepublishOnly":"node-gyp clean && rm -f fsevents.node && node-gyp rebuild && node-gyp clean"},"_npmUser":{"name":"pipobscure","email":"pip@pipobscure.com"},"repository":{"url":"git+https://github.com/fsevents/fsevents.git","type":"git"},"_npmVersion":"6.7.0","description":"Native Access to Mac OS-X FSEvents","directories":{},"_nodeVersion":"11.14.0","_hasShrinkwrap":false,"readmeFilename":"README.md","devDependencies":{},"_npmOperationalInternal":{"tmp":"tmp/fsevents_2.0.5_1555433424663_0.05713479282296485","host":"s3://npm-registry-packages"}},"2.0.6":{"name":"fsevents","version":"2.0.6","keywords":["fsevents","mac"],"license":"MIT","_id":"fsevents@2.0.6","maintainers":[{"name":"bajtos","email":"mbajtoss@gmail.com"},{"name":"bnoordhuis","email":"info@bnoordhuis.nl"},{"name":"es128","email":"elan.shanker+npm@gmail.com"},{"name":"paulmillr","email":"paul@paulmillr.com"},{"name":"pipobscure","email":"pip@pipobscure.com"}],"contributors":[{"name":"Philip