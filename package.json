{
  "name": "cvkonnekt",
  "version": "1.0.0",
  "description": "CV Builder for South Africans",
  "main": "improved-server.js",
  "scripts": {
    "start": "node improved-server.js",
    "server": "nodemon improved-server.js",
    "client": "vite",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "postinstall": "npm run build",
    "tailwind": "npx tailwindcss -i ./src/styles/input.css -o ./dist/output.css --watch",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "generate-icons": "node scripts/generate-icons.js",
    "check-supabase": "node scripts/check-supabase-config.js",
    "build:cpanel": "node scripts/build-for-cpanel.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "resume",
    "cv",
    "builder",
    "south africa"
  ],
  "author": "CVKonnekt",
  "license": "ISC",
  "dependencies": {
    "@azure/arm-appinsights": "4.0.0",
