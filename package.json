    "react-dom": "^18.2.0",
    "react-router-dom": "6.22.3",
    "react-swipeable": "^7.0.1",
    "sharp": "^0.33.2",
    "tailwindcss": "^3.4.1",
    "winston": "3.17.0"
  },
